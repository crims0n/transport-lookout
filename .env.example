SCANPOD_DATABASE_URL=postgresql+psycopg://scanpod:scanpod@postgres:5432/scanpod
SCANPOD_AMQP_URL=amqp://scanpod:scanpod@rabbitmq:5672/
SCANPOD_BOOTSTRAP_TOKEN=change-me-before-use
SCANPOD_BOOTSTRAP_ENABLED=true
SCANPOD_CORS_ORIGINS=http://localhost:5173
