SCANPOD_DATABASE_URL=postgresql+psycopg://scanpod:scanpod@postgres:5432/scanpod
SCANPOD_AMQP_URL=amqp://scanpod:scanpod@rabbitmq:5672/
SCANPOD_BOOTSTRAP_TOKEN=change-me-before-use
SCANPOD_BOOTSTRAP_ENABLED=true
SCANPOD_CORS_ORIGINS=http://localhost:5173
# Local development keeps raw scan XML on the worker filesystem.
SCANPOD_ARTIFACT_BACKEND=filesystem
# Production S3-compatible storage (credentials come from the worker environment).
# SCANPOD_ARTIFACT_BACKEND=s3
# SCANPOD_ARTIFACT_S3_BUCKET=transport-lookout-artifacts
# SCANPOD_ARTIFACT_S3_PREFIX=transport-lookout
# SCANPOD_ARTIFACT_S3_REGION=us-east-1
# SCANPOD_ARTIFACT_S3_ENDPOINT_URL=https://s3.example.com
# Production: disable bootstrap and configure a validating OIDC issuer.
# SCANPOD_BOOTSTRAP_ENABLED=false
# SCANPOD_OIDC_ISSUER=https://idp.example.com/realms/security
# SCANPOD_OIDC_AUDIENCE=scanpod-enterprise
